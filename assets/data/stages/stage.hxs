function create()
{
    var bg = new FlxSprite(-600, -600).loadGraphic(Assets.image("stages/stage/stageback"));
    bg.scrollFactor.set(0.6, 0.6);
    add(bg);
    
    var front = new FlxSprite(-580, 440);
    front.loadGraphic(Assets.image("stages/stage/stagefront"));
    add(front);

    var curtains = new FlxSprite(-600, -400).loadGraphic(Assets.image("stages/stage/stagecurtains"));
    curtains.scrollFactor.set(1.4,1.4);
    curtains.setZ(11);
    add(curtains);
}