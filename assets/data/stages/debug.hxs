import doido.song.Timings;
import flixel.FlxG;
import flixel.math.FlxMath;
import flixel.tweens.FlxEase;
import flixel.tweens.FlxTween;

var bandu:FlxSprite;

function create()
{
    var bg = new FlxSprite().loadGraphic(Assets.image('stages/debug/fat'));
    bg.screenCenter();
    bg.scale.set(2.5, 2.5);
    bg.scrollFactor.set(0.7, 0.7);
    add(bg);

    gfScrollFactor.x = 0.85;
    gfScrollFactor.y = 0.85;

    bandu = new FlxSprite().loadGraphic(Assets.image('stages/debug/bandu'), true, (678 / 6), 162);
    bandu.animation.add("idle", [0,1,2,3,4], 12, true);
    bandu.animation.add("sad", [5], 0, true);
    bandu.animation.play("idle");
    bandu.antialiasing = false;
    add(bandu);

    setZ(playState.bf, 16);

    // preload
    Assets.sound("editors/clank");
}

var elapsedtime:Float = 0.0;
var sadTimer:Float = 0.0;
var punchVelocity:Float = 0.0;
var punchDir:Int = 0;

function update(elapsed)
{
    if (sadTimer <= 0.0)
    {
        bandu.animation.play("idle");
        elapsedtime += elapsed * 1.5;
    }
    else
    {
        bandu.animation.play("sad");
        sadTimer -= elapsed;
    }

    if (FlxG.mouse.justPressed)
    {
        if (FlxG.mouse.overlaps(bandu)) {
            FlxG.sound.play(Assets.sound("editors/clank"));
            punchVelocity += -0.2 * punchDir;
        }
    }
    if (Math.abs(punchVelocity) > 0.01)
    {
        sadTimer = 0.1;
        punchVelocity = FlxMath.lerp(punchVelocity, 0.0, elapsed * 2);
        elapsedtime -= punchVelocity;
    }

    bandu.setPosition(
        playState.bf.x - (bandu.width / 2),
        playState.bf.y - playState.bf.height * 0.8
    );

    var prevX:Float = bandu.x;

    bandu.y += Math.cos(elapsedtime / 4) * 80;
    bandu.x += Math.sin(elapsedtime) * playState.bf.width * 0.6;

    punchDir = (bandu.x > prevX) ? 1 : -1;

    bandu.scale.x = bandu.scale.y = 1.0 + Math.cos(elapsedtime) * 0.3;
    setZ(bandu, bandu.scale.x < 1.0 ? 15 : 17);
}

// good job you made him sad
function onNoteMiss(note, strumline)
{
    if (strumline.isPlayer)
    {
        sadTimer = 1.2;
    }
}

// if bandu is sad, it makes bandu not sad
// if you hit a 20x combo he does a little spin
function onNoteHit(note, strumline)
{
    if (strumline.isPlayer)
    {
        sadTimer = 0.0;
        if (Timings.combo % 20 == 0 && Timings.combo > 0 && !note.isHold)
        {
            bandu.angle = 0;
            FlxTween.completeTweensOf(bandu);
            FlxTween.tween(bandu, {angle: 360 * FlxG.random.sign()}, 1.0, {
                ease: FlxEase.cubeOut
            });
        }
    }
}

// make bandu flip, why not
function onGhostTap(lane, punchDirection)
{
    bandu.flipX = !bandu.flipX;
}